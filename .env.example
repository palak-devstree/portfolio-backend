# =============================================================================
# Portfolio Backend - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# =============================================================================
# Database (Neon PostgreSQL)
# =============================================================================
# Use Neon's pooled connection endpoint (port 5432) for serverless-friendly connections
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/portfolio?sslmode=require

# =============================================================================
# Cache (Upstash Redis)
# =============================================================================
# Upstash Redis URL — supports both rediss:// (TLS) and redis:// protocols
REDIS_URL=rediss://default:password@us1-xxx.upstash.io:6379

# =============================================================================
# Security
# =============================================================================
# Secret key for JWT token signing — use a long random string (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# =============================================================================
# Admin Credentials
# =============================================================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password
ADMIN_EMAIL=admin@example.com

# =============================================================================
# SMTP Email Configuration
# =============================================================================
# SMTP server settings for contact form notifications
# Examples:
#   Gmail: smtp.gmail.com:587 (use App Password, not regular password)
#   SendGrid: smtp.sendgrid.net:587
#   Mailgun: smtp.mailgun.org:587
#   AWS SES: email-smtp.us-east-1.amazonaws.com:587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Portfolio Contact Form

# =============================================================================
# AI Provider (Gemini or OpenAI)
# =============================================================================
# Provider: "gemini" (default, 1500 req/day free) or "openai"
AI_PROVIDER=gemini

# Model name:
#   Gemini: "gemini-1.5-flash" (fast, free tier) or "gemini-1.5-pro"
#   OpenAI: "gpt-4o-mini" (cheap) or "gpt-4o"
AI_MODEL=gemini-1.5-flash

# API key for the selected provider
# Gemini: https://makersuite.google.com/app/apikey
# OpenAI: https://platform.openai.com/api-keys
AI_API_KEY=your-ai-api-key-here

# =============================================================================
# Cloudinary (Image/Diagram Storage)
# =============================================================================
# Free tier: 25GB storage, 25GB bandwidth/month
# Get credentials at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
# Production: your Vercel frontend URL
# Development: http://localhost:5173 (Vite default)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-portfolio.vercel.app

# =============================================================================
# Application
# =============================================================================
# Environment: "development" or "production"
ENVIRONMENT=development

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API base URL (used by GitHub Actions workflows)
API_BASE_URL=https://your-api.onrender.com
